#include <winver.h>

#define IDI_ENTROPY_APP_ICON 101

IDI_ENTROPY_APP_ICON ICON "@entropy_WINDOWS_APP_ICON@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @VERSION_MAJOR@,@VERSION_MINOR@,@VERSION_FEATURE@,@VERSION_PATCH@
 PRODUCTVERSION @VERSION_MAJOR@,@VERSION_MINOR@,@VERSION_FEATURE@,@VERSION_PATCH@
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "@ORG_NAME_1@\0"
      VALUE "FileDescription", "@APP_DESCRIPTION@\0"
      VALUE "FileVersion", "@VERSION_FULL@\0"
      VALUE "InternalName", "entropy\0"
      VALUE "LegalCopyright", "@COPYRIGHT_LINE@\0"
      VALUE "OriginalFilename", "entropy.exe\0"
      VALUE "ProductName", "@APP_NAME@\0"
      VALUE "ProductVersion", "@VERSION_FULL@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
