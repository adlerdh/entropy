if(CPACK_GENERATOR STREQUAL "ZIP")
  set(CPACK_PACKAGE_FILE_NAME "@APP_NAME@-@VERSION_FULL@-Windows-@Entropy_PACKAGE_ARCHITECTURE@-portable")
  set(CPACK_ARCHIVE_FILE_NAME "${CPACK_PACKAGE_FILE_NAME}")
elseif(CPACK_GENERATOR STREQUAL "WIX")
  set(CPACK_PACKAGE_FILE_NAME "@APP_NAME@-@VERSION_FULL@-Windows-@Entropy_PACKAGE_ARCHITECTURE@")
endif()
