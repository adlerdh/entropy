if(CPACK_GENERATOR STREQUAL "ZIP")
  set(CPACK_PACKAGE_FILE_NAME "@APP_NAME@-@VERSION_FULL@-Windows-@CMAKE_SYSTEM_PROCESSOR@-portable")
  set(CPACK_ARCHIVE_FILE_NAME "${CPACK_PACKAGE_FILE_NAME}")
elseif(CPACK_GENERATOR STREQUAL "WIX")
  set(CPACK_PACKAGE_FILE_NAME "@APP_NAME@-@VERSION_FULL@-Windows-@CMAKE_SYSTEM_PROCESSOR@")
endif()
